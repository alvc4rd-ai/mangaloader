# ─────────────────────────────────────────────────────────────────────────────
# mangaloader configuration. Copy this file to `.env.local` and fill it in.
# `.env.local` is gitignored — never commit real tokens.
# ─────────────────────────────────────────────────────────────────────────────

# ── LibSocial auth (MangaLib / HentaiLib / SlashLib) ─────────────────────────
# A bearer token (JWT) is the simplest setup — paste a long-lived (e.g. 30-day)
# token from a logged-in lib.me session. nHentai needs no auth.
ATLAS_CONTENT_ARCHIVE_MANGALIB_BEARER_TOKEN=
# Alternate names also accepted (first non-empty wins):
# MANGALIB_BEARER_TOKEN=
# LIBSOCIAL_AUTHORIZATION=

# Optional: a refresh token so mangaloader can mint bearer tokens itself.
# NOTE: LibSocial (Laravel Passport) rotates refresh tokens on every use and
# revokes the old one — use a DEDICATED private-window login so refreshing here
# does not log your everyday browser session out.
# MANGALIB_REFRESH_TOKEN=
# LIBSOCIAL_REFRESH_TOKEN=

# Optional: override the LibSocial auth/API base.
# LIBSOCIAL_AUTH_BASE=https://api.cdnlibs.org/api

# ── DDoS-Guard image cookie (Server 1 / Server 2 originals) ──────────────────
# Server 1/2 hosts sit behind DDoS-Guard. Export the Cookie header while
# browsing the image host through your VPN IP and paste it here. Optional —
# only needed if a full-tunnel VPN alone is not enough.
# ATLAS_CONTENT_ARCHIVE_IMAGE_COOKIE=
# Per-source overrides:
# ATLAS_CONTENT_ARCHIVE_MANGALIB_IMAGE_COOKIE=
# ATLAS_CONTENT_ARCHIVE_HENTAILIB_IMAGE_COOKIE=
# ATLAS_CONTENT_ARCHIVE_SLASHLIB_IMAGE_COOKIE=

# ── Output + Google Drive upload ─────────────────────────────────────────────
# Local output root for CBZ files and run records (default: .atlas-backups).
# ATLAS_BACKUP_ROOT=.atlas-backups

# rclone remote used by the "Archive" / --upload path. Without it, finished CBZ
# files stay local only. Example: gdrive: (configure with `rclone config`).
# ATLAS_CONTENT_ARCHIVE_DRIVE_REMOTE=gdrive:
# ATLAS_BACKUP_DRIVE_REMOTE=gdrive:

# ── Pacing (optional) ────────────────────────────────────────────────────────
# Delay between page downloads (ms) to avoid 429 rate limits. Defaults are
# source-tuned (LibSocial ~400ms, nHentai 0). Per-source or global override:
# ATLAS_CONTENT_ARCHIVE_MANGALIB_PAGE_DELAY_MS=400
# ATLAS_CONTENT_ARCHIVE_PAGE_DELAY_MS=400
