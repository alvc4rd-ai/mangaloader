{
  "name": "mangaloader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--use-system-ca next dev",
    "build": "NODE_OPTIONS=--use-system-ca next build",
    "start": "NODE_OPTIONS=--use-system-ca next start",
    "typecheck": "tsc --noEmit",
    "archive:mangalib": "NODE_OPTIONS=--use-system-ca tsx scripts/content-archive/archive-mangalib-title.ts --source=mangalib",
    "archive:nhentai": "NODE_OPTIONS=--use-system-ca tsx scripts/content-archive/archive-mangalib-title.ts --source=nhentai",
    "archive:slashlib": "NODE_OPTIONS=--use-system-ca tsx scripts/content-archive/archive-mangalib-title.ts --source=slashlib",
    "archive:hentailib": "NODE_OPTIONS=--use-system-ca tsx scripts/content-archive/archive-mangalib-title.ts --source=hentailib",
    "archive:calibrate": "NODE_OPTIONS=\"--use-system-ca --conditions=react-server\" tsx scripts/content-archive/calibrate-content-archive.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
